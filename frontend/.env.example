# ── Dev server (Vite) ─────────────────────────────────────────────
# Backend URL for the Vite dev-server proxy (npm run dev).
# Only used during local development.
VITE_BACKEND_URL=http://localhost:8000

# Set this when the frontend and backend are served from DIFFERENT origins
# (e.g. frontend on a CDN, backend on a separate domain).
# Leave blank when using a reverse proxy (nginx) in front of both.
# VITE_API_URL=https://api.example.com

# ── Production container (nginx) ──────────────────────────────────
# Backend URL that nginx proxies /api and /ws requests to.
BACKEND_URL=http://backend:8000

# Port nginx listens on inside the container.
NGINX_PORT=80

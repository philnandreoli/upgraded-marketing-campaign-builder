# Microsoft Entra (Azure AD) Application Registration
# These values are exposed to the browser — do NOT put client secrets here.

# Application (client) ID of your registered app in Microsoft Entra.
# Leave empty to disable authentication (useful for local development).
VITE_AZURE_CLIENT_ID=

# Directory (tenant) ID — use "common" to allow any tenant, or set your specific tenant ID.
VITE_AZURE_TENANT_ID=common

# Optional: override the OAuth redirect URI (defaults to the current browser origin).
# VITE_REDIRECT_URI=http://localhost:5173

# Optional: API scope for your backend.
# Use "api://<backend-client-id>/access_as_user" when the backend is registered
# as a separate API in Entra.  Leave empty to use "openid profile email".
# VITE_API_SCOPE=api://your-backend-client-id/access_as_user

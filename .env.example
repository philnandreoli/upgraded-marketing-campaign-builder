# Azure AI Foundry Project Configuration
AZURE_AI_PROJECT_ENDPOINT=https://your-ai-services-account-name.services.ai.azure.com/api/projects/your-project-name
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4

# Application Settings
APP_ENV=development
APP_PORT=8001
APP_LOG_LEVEL=INFO

# Agent Settings
AGENT_MAX_RETRIES=3
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096

# Authentication / Authorization (OAuth 2.0 / OIDC)
# Set AUTH_ENABLED=true to enforce JWT authentication on all campaign endpoints.
# When false (default), auth is skipped — useful for local development.
AUTH_ENABLED=false
# OIDC authority URL — for Microsoft Entra use:
#   https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUTHORITY=
# Application (client) ID registered in the identity provider.
OIDC_CLIENT_ID=
# Optional: seconds to cache OIDC provider public keys (default: 3600)
# OIDC_JWKS_CACHE_TTL=3600

# Tracing / Observability
# Set to true to enable OpenTelemetry tracing of LLM calls
TRACING_ENABLED=false
# Exporter: console (stdout), otlp (Aspire Dashboard / OTLP backend), azure_monitor
TRACING_EXPORTER=console
# OTLP endpoint (only used when TRACING_EXPORTER=otlp)
OTLP_ENDPOINT=http://localhost:4317
# Azure Monitor connection string (only used when TRACING_EXPORTER=azure_monitor).
# If left empty, it is automatically retrieved from the AI Foundry project.
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Capture LLM message content in traces (may contain sensitive data)
TRACING_CONTENT_RECORDING=true

# Foundry Agent Operations
# Set to true to register marketing agents as AI Foundry Agent versions.
# When enabled, LLM calls go through the Foundry agent_reference path,
# giving you server-side agent identity, versioning, and portal visibility.
FOUNDRY_AGENTS_ENABLED=false

# Workflow Executor
# Controls how pipeline jobs are dispatched. Options: in_process, azure_service_bus
WORKFLOW_EXECUTOR=in_process

# Azure Service Bus (only when WORKFLOW_EXECUTOR=azure_service_bus)
AZURE_SERVICE_BUS_NAMESPACE=
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=workflow-jobs

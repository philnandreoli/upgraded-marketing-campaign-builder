# Azure AI Foundry Project Configuration
AZURE_AI_PROJECT_ENDPOINT=https://your-ai-services-account-name.services.ai.azure.com/api/projects/your-project-name
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4

# Application Settings
APP_ENV=development
APP_PORT=8001
APP_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
# Controls which browser origins are allowed to make cross-origin API
# requests.  The value must be a JSON array string.
#
# When the React frontend is served by the same nginx reverse-proxy that
# proxies API traffic (the default production topology), the browser sees
# a single origin and CORS is not exercised — this setting mainly guards
# direct API access from other origins (e.g. a separate staging frontend).
#
# Development (default — permissive, do NOT use in production):
# CORS_ALLOWED_ORIGINS=["*"]
#
# Production example — set to your actual frontend origin(s).
# The value must be a JSON array string:
# CORS_ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]

# Agent Settings
AGENT_MAX_RETRIES=3
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096

# Authentication / Authorization (OAuth 2.0 / OIDC)
# AUTH_ENABLED controls JWT authentication for all campaign API endpoints.
# IMPORTANT: Must be set to true in all non-development environments.
# The application will refuse to start if AUTH_ENABLED=false outside of
# APP_ENV=development or APP_ENV=test.
AUTH_ENABLED=false
# OIDC authority URL — for Microsoft Entra use:
#   https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUTHORITY=
# Application (client) ID registered in the identity provider.
OIDC_CLIENT_ID=
# Optional: seconds to cache OIDC provider public keys (default: 3600)
# OIDC_JWKS_CACHE_TTL=3600
#
# Entra ID Directory Search (optional — enables "Add User from Directory" in the Admin panel)
# To enable admins to search and pre-provision users from Microsoft Entra ID:
#   1. Add User.Read.All application permission to the app registration and grant admin consent.
#   2. Create a client secret in Certificates & Secrets and set it below.
# AZURE_CLIENT_SECRET=

# Tracing / Observability
# Set to true to enable OpenTelemetry tracing of LLM calls
TRACING_ENABLED=false
# Exporter: console (stdout), otlp (Aspire Dashboard / OTLP backend), azure_monitor
TRACING_EXPORTER=console
# OTLP endpoint (only used when TRACING_EXPORTER=otlp)
OTLP_ENDPOINT=http://localhost:4317
# Azure Monitor connection string (only used when TRACING_EXPORTER=azure_monitor).
# If left empty, it is automatically retrieved from the AI Foundry project.
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Capture LLM message content in traces (may contain sensitive data)
TRACING_CONTENT_RECORDING=true

# Foundry Agent Operations
# Set to true to register marketing agents as AI Foundry Agent versions.
# When enabled, LLM calls go through the Foundry agent_reference path,
# giving you server-side agent identity, versioning, and portal visibility.
FOUNDRY_AGENTS_ENABLED=false

# Workflow Executor
# Controls how pipeline jobs are dispatched. Options: in_process, azure_service_bus
WORKFLOW_EXECUTOR=in_process

# Azure Service Bus (only when WORKFLOW_EXECUTOR=azure_service_bus)
AZURE_SERVICE_BUS_NAMESPACE=
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=workflow-jobs

# Worker Settings (only when running the standalone worker)
# Maximum number of simultaneous pipeline executions
WORKER_MAX_CONCURRENCY=3
# Seconds to wait for active jobs to complete during graceful shutdown
WORKER_SHUTDOWN_TIMEOUT_SECONDS=300
# TCP port for the worker health HTTP endpoint (/health/live, /health/ready)
WORKER_HEALTH_PORT=8001

# ---------------------------------------------------------------------------
# Database Authentication
# ---------------------------------------------------------------------------
# DB_AUTH_MODE controls how the API, worker, and migration job authenticate
# to PostgreSQL.  Two modes are supported:
#
#   local (default)
#     Traditional password-based connection.  Set DATABASE_URL to your
#     local or self-hosted PostgreSQL instance.
#
#   azure
#     Microsoft Entra / managed identity authentication for Azure Database
#     for PostgreSQL Flexible Server.  Access tokens are obtained via
#     DefaultAzureCredential (managed identity / workload identity) — no
#     long-lived passwords are stored or transmitted.  Set the three
#     AZURE_POSTGRES_* variables below instead of DATABASE_URL.
#
# Local development (default):
DB_AUTH_MODE=local
# Required when DB_AUTH_MODE=local: PostgreSQL connection string.
# Copy and adjust the example below. The application will refuse to start
# if this is unset in local auth mode.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/campaigns

# Azure cloud mode (set DB_AUTH_MODE=azure and fill in the values below):
# DB_AUTH_MODE=azure
# AZURE_POSTGRES_HOST=<yourserver>.postgres.database.azure.com
# AZURE_POSTGRES_DATABASE=campaigns
# AZURE_POSTGRES_USER=<managed-identity-principal-name>
#
# Each workload identity (API, worker, migration job) must be granted a
# PostgreSQL role.  Connect as the Entra admin and run:
#   CREATE ROLE "<managed-identity-name>" WITH LOGIN;
#   GRANT CONNECT ON DATABASE campaigns TO "<managed-identity-name>";
#   GRANT USAGE ON SCHEMA public TO "<managed-identity-name>";
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public
#     TO "<managed-identity-name>";

# ---------------------------------------------------------------------------
# API Startup Migration Behaviour
# ---------------------------------------------------------------------------
# API_AUTO_MIGRATE controls whether the API applies Alembic migrations on
# startup or only validates that the schema is already at the expected head.
#
#   true  — API runs "alembic upgrade head" at startup (local dev default).
#           Convenient for developers: no separate migration step needed.
#
#   false — API validates the schema version and refuses to start if the
#           schema is behind (or ahead of) the expected revision.  Schema
#           changes must be applied by the dedicated migration job
#           (backend.apps.migrate.main) *before* the API is started.
#           This is the default in azure mode and is the recommended setting
#           for all cloud-hosted environments.
#
# When not set the default is derived from DB_AUTH_MODE:
#   DB_AUTH_MODE=local  → API_AUTO_MIGRATE defaults to true
#   DB_AUTH_MODE=azure  → API_AUTO_MIGRATE defaults to false
#
# Local development (default — leave unset or set explicitly):
# API_AUTO_MIGRATE=true

# Azure cloud deployments (set explicitly in Container App environment):
# API_AUTO_MIGRATE=false
